FROM node:20-alpine

WORKDIR /app

# Install build tools for native dependencies and OCR image conversion
RUN apk add --no-cache python3 make g++ ghostscript graphicsmagick

# Copy package.json and package-lock.json
COPY package*.json ./

# Install dependencies (only production)
RUN npm install --production --legacy-peer-deps

# Copy server code
COPY server/ ./server/

# Set environment variables
ENV NODE_ENV=production
ENV PORT=3001
ENV OLLAMA_BASE_URL=http://ollama-service:11434

# Create data directory
RUN mkdir -p /app/server/data/uploads /app/server/data/vectorstores

EXPOSE 3001

CMD ["node", "server/index.js"]
