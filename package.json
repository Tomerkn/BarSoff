{
  "name": "barsuf",
  "private": true,
  "version": "1.0.7",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node server/index.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "auto-deploy": "while true; do echo 'Checking for updates...'; git pull origin main | grep -q 'Already up to date.' || (echo 'New version found! Deploying...' && gcloud run deploy barsuf --source . --region us-central1 --allow-unauthenticated); sleep 600; done"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@google-cloud/storage": "^5.18.3",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.2.4",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "langchain": "^1.3.4",
    "lucide-react": "^0.475.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-draggable": "^4.4.6",
    "react-is": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.0.0",
    "vector-storage": "^1.0.55"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "5.4.11"
  }
}
